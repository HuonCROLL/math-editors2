{
    "name": "@huoncroll/math-editors",
    "version": "1.0.17",
    "description": "MathLiveEditor, ExplanationEditor, and TiptapEditor with inline math - shared across Huons repos",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup src/index.tsx --format cjs,esm --dts --watch"
    },
    "peerDependencies": {
        "@emotion/react": "^11.0.0",
        "@emotion/styled": "^11.0.0",
        "@mui/icons-material": "^5.0.0 || ^6.0.0 || ^7.0.0",
        "@mui/material": "^5.0.0 || ^6.0.0 || ^7.0.0",
        "@tiptap/core": "^2.0.0 || ^3.0.0",
        "@tiptap/extension-mathematics": "^2.0.0 || ^3.0.0",
        "@tiptap/extension-table": "^2.0.0 || ^3.0.0",
        "@tiptap/extension-table-cell": "^2.0.0 || ^3.0.0",
        "@tiptap/extension-table-header": "^2.0.0 || ^3.0.0",
        "@tiptap/extension-table-row": "^2.0.0 || ^3.0.0",
        "@tiptap/extension-text-align": "^2.0.0 || ^3.0.0",
        "@tiptap/extension-text-style": "^2.0.0 || ^3.0.0",
        "@tiptap/react": "^2.0.0 || ^3.0.0",
        "@tiptap/starter-kit": "^2.0.0 || ^3.0.0",
        "katex": "^0.16.0",
        "mathlive": ">=0.100.0 <1.0.0",
        "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
        "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
        "tiptap-extension-resize-image": "^1.0.0"
    },
    "devDependencies": {
        "@types/katex": "^0.16.0",
        "@types/react": "^18.0.0 || ^19.0.0",
        "@types/react-dom": "^18.0.0 || ^19.0.0",
        "tsup": "^8.0.0",
        "typescript": "^4.9.0 || ^5.0.0"
    }
}
